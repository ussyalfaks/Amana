PORT=4000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Pinata IPFS
PINATA_API_KEY=
PINATA_SECRET=
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

STELLAR_NETWORK=TESTNET
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Soroban contract addresses (from stellar network deployment)
# AMANA_ESCROW_CONTRACT_ID: the deployed Amana escrow contract address
AMANA_ESCROW_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# USDC_CONTRACT_ID: the USDC token contract address on the target network
USDC_CONTRACT_ID=CYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

## Required
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-chars-change-in-production!
JWT_EXPIRES_IN=86400  # 24 hours in seconds

## Redis for challenge storage (TTL replay protection)
REDIS_URL=redis://localhost:6379/0

## Optional existing
# PORT=4000
# DATABASE_URL=postgresql://...
# SUPABASE_URL=...
# SUPABASE_ANON_KEY=...
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org


